{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["../src/*"],
      "@libs/*": ["../src/libs/*"],
      "@plugins/*": ["../plugins/*"]
    }
  },
  "include": [
    "main/**/*.ts",
    "preload/**/*.ts",
    "lib/**/*.ts"
  ]
}
